# Production Environment Variables
# Copy this to .env on your VPS and fill with real values

# Database (used by Docker Compose)
DB_PASSWORD=your_secure_database_password_here_min_16_chars

# JWT Secret (for authentication tokens)
JWT_SECRET=your_very_long_random_secret_key_minimum_64_characters_here_use_openssl_rand_base64_64

# Node Environment
NODE_ENV=production
