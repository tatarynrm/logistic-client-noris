// Prisma Schema
// Documentation: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Models
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenders   Tender[]

  @@index([email])
  @@map("users")
}

model Tender {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  loadDate      DateTime      @map("load_date")
  unloadDate    DateTime?     @map("unload_date")
  driverName    String        @map("driver_name")
  driverPhone   String        @map("driver_phone")
  vehicleInfo   String        @map("vehicle_info")
  ownerName     String?       @map("owner_name")
  ownerPhone    String?       @map("owner_phone")
  clientName    String        @map("client_name")
  clientPhone   String?       @map("client_phone")
  clientPayment Float         @map("client_payment")
  myMargin      Float         @map("my_margin")
  marginPayer   String        @default("CLIENT") @map("margin_payer")
  status        String        @default("PENDING")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  routes        TenderRoute[]
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loadDate])
  @@index([status])
  @@index([createdAt])
  @@map("tenders")
}

model TenderRoute {
  id          String   @id @default(cuid())
  tenderId    String   @map("tender_id")
  type        String
  sequence    Int
  name        String
  lat         Float
  lng         Float
  displayName String   @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")
  tender      Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@unique([tenderId, sequence])
  @@index([tenderId])
  @@index([type])
  @@map("tender_routes")
}
