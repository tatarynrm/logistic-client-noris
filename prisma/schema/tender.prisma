model Tender {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  loadDate      DateTime      @map("load_date")
  unloadDate    DateTime?     @map("unload_date")
  driverName    String        @map("driver_name")
  driverPhone   String        @map("driver_phone")
  vehicleInfo   String        @map("vehicle_info")
  ownerName     String?       @map("owner_name")
  ownerPhone    String?       @map("owner_phone")
  clientName    String        @map("client_name")
  clientPhone   String?       @map("client_phone")
  clientPayment Float         @map("client_payment")
  myMargin      Float         @map("my_margin")
  marginPayer   MarginPayer   @default(CLIENT) @map("margin_payer")
  status        TenderStatus  @default(PENDING)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  routes        TenderRoute[]
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loadDate])
  @@index([status])
  @@index([createdAt])
  @@map("tenders")
}
