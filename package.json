    "@tanstack/react-query-devtools": "^5.28.4",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.2",
    "next": "^14.2.0",
    "pg": "^8.19.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.51.0",
